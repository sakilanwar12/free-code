# Freepilot Configuration

# Provider: openrouter (default), ollama, deepseek, openai
FREEPILOT_PROVIDER=openrouter

# ========== OPENROUTER (default, free tier available) ==========
# Get free API key: https://openrouter.ai/keys
#
# Recommended free models for coding:
#   deepseek/deepseek-chat-v3:free          ← Default (fast, good reasoning)
#   qwen/qwen-2.5-coder-32b-instruct:free   ← Best for code generation
#   deepseek/deepseek-r1:free               ← Debugging/reasoning
#   meta-llama/llama-3.3-70b-instruct:free  ← Stable fallback
#   google/gemma-3-27b-it:free              ← Fast, lightweight
#   openrouter/free                         ← Auto-selects best free model
OPENROUTER_API_KEY=sk-or-your-key-here
FREEPILOT_MODEL=deepseek/deepseek-chat-v3:free

# ========== OLLAMA (local, completely free, no API key) ==========
# Install: https://ollama.ai
# FREEPILOT_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=codellama

# ========== DEEPSEEK (free API tier) ==========
# Get free API key: https://platform.deepseek.com/api_keys
# FREEPILOT_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# FREEPILOT_MODEL=deepseek-chat

# ========== OPENAI (requires API key) ==========
# FREEPILOT_PROVIDER=openai
# OPENAI_API_KEY=sk-your-api-key-here
# FREEPILOT_MODEL=gpt-4o-mini

# ========== General ==========
# FREEPILOT_MAX_TOKENS=4096
# FREEPILOT_TEMPERATURE=0.7
# FREEPILOT_AUTO_ACCEPT=false
